# Environment Variables - Copy to .env and update values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sk_agrovet_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sk_agrovet_db
DB_USER=postgres
DB_PASSWORD=your_password

# Backend Server
BACKEND_PORT=5000
BACKEND_URL=http://localhost:5000
NODE_ENV=development

# Frontend
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# SMS Service (for AI reminders)
SMS_PROVIDER=africastalking
AFRICASTALKING_API_KEY=your_api_key
AFRICASTALKING_USERNAME=your_username

# M-Pesa Integration
MPESA_CONSUMER_KEY=your_key
MPESA_CONSUMER_SECRET=your_secret
MPESA_SHORTCODE=123456
MPESA_PASSKEY=your_passkey

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mwangiwakamau9@gmail.com
SMTP_PASS=Mw@ng!001.
SMTP_FROM=noreply@skagrovet.com

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# CORS
CORS_ORIGIN=http://localhost:3000
